  </div>

</main>

<script>
/* ── PROGRESS TRACKING ── */
const done = {A:false,B:false,C:false,D:false};
function markDone(k,dotId){
  done[k]=true;
  const d=document.getElementById(dotId);
  d.textContent='✓';d.style.background='var(--gold)';d.style.color='#fff';
  checkFinish();
}
function checkFinish(){
  if(Object.values(done).every(Boolean)) document.getElementById('finishBanner').classList.add('show');
}

/* ── REVEAL BOX ── */
function toggleReveal(id){const el=document.getElementById(id);el.classList.toggle('open')}

/* ═══ ACTIVITY A: MATCH ═══ */
let selTerm=null,selDef=null,matchCount=0;
function pickTerm(el){
  if(el.classList.contains('matched'))return;
  document.querySelectorAll('.match-term').forEach(t=>t.classList.remove('selected'));
  el.classList.add('selected');selTerm=el;
  if(selDef)tryMatch();
}
function pickDef(el){
  if(el.classList.contains('matched'))return;
  document.querySelectorAll('.match-def').forEach(d=>d.classList.remove('selected'));
  el.classList.add('selected');selDef=el;
  if(selTerm)tryMatch();
}
function tryMatch(){
  if(selTerm.dataset.id===selDef.dataset.id){
    selTerm.classList.remove('selected');selTerm.classList.add('matched');
    selDef.classList.remove('selected');selDef.classList.add('matched');
    matchCount++;
    document.getElementById('matchScore').textContent=matchCount+'/6 matched ✓';
    if(matchCount===6){document.getElementById('matchScore').textContent='✅ All 6 matched — well done!';markDone('A','pd1');}
  }else{
    selTerm.classList.add('wrong-flash');selDef.classList.add('wrong-flash');
    setTimeout(()=>{selTerm.classList.remove('wrong-flash','selected');selDef.classList.remove('wrong-flash','selected');},400);
  }
  selTerm=null;selDef=null;
}

/* ═══ ACTIVITY B: FILL BLANKS ═══ */
let selChip=null;
function selectChip(el){
  if(el.classList.contains('used'))return;
  document.querySelectorAll('.fill-chip').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');selChip=el;
}
function placeWord(blank){
  if(!selChip)return;
  if(blank.classList.contains('revealed'))return;
  blank.dataset.placed=selChip.dataset.word;
  blank.textContent=selChip.dataset.word;
  blank.style.color='var(--navy)';blank.style.background='var(--blue-bg)';
  selChip.classList.add('used');selChip.classList.remove('selected');selChip=null;
}
function checkFill(){
  const blanks=document.querySelectorAll('.blank');
  let correct=0,total=blanks.length;
  blanks.forEach(b=>{
    b.classList.remove('revealed','wrong');
    if(b.dataset.placed===b.dataset.answer){b.classList.add('revealed');correct++;}
    else if(b.dataset.placed){b.classList.add('wrong');}
  });
  const fb=document.getElementById('fillFeedback');
  fb.style.display='block';
  if(correct===total){
    fb.style.background='var(--green-bg)';fb.style.color='var(--green)';
    fb.textContent='✅ All '+total+' correct — excellent!';
    markDone('B','pd2');
  }else{
    fb.style.background='var(--red-bg)';fb.style.color='var(--red)';
    fb.textContent=correct+'/'+total+' correct. Red blanks are wrong — try again.';
  }
}
function resetFill(){
  document.querySelectorAll('.blank').forEach(b=>{b.dataset.placed='';b.textContent='________';b.style.color='transparent';b.style.background='var(--gold-pale)';b.classList.remove('revealed','wrong');});
  document.querySelectorAll('.fill-chip').forEach(c=>{c.classList.remove('used','selected');});
  selChip=null;document.getElementById('fillFeedback').style.display='none';
}

/* ═══ ACTIVITY C: SORT ═══ */
let dragged=null;
function sStart(e){dragged=e.target;setTimeout(()=>{if(dragged)dragged.style.opacity='.4';},0);}
function sOver(e){e.preventDefault();e.currentTarget.classList.add('over');}
function sLeave(e){e.currentTarget.classList.remove('over');}
function sDrop(e,zone){
  e.preventDefault();e.currentTarget.classList.remove('over');
  const target=zone==='bank'?document.getElementById('sortBank'):document.getElementById('zone-'+zone);
  if(dragged&&target){dragged.style.opacity='1';target.appendChild(dragged);dragged=null;}
}
function checkSort(){
  const cards=document.querySelectorAll('.sort-card');
  let correct=0,total=0;
  cards.forEach(c=>{
    const p=c.closest('.drop-zone')||c.closest('#sortBank');
    if(!p||p.id==='sortBank')return;
    total++;c.classList.remove('correct-slot','wrong-slot');
    const zone=p.id.replace('zone-','');
    if(zone===c.dataset.correct){c.classList.add('correct-slot');correct++;}
    else c.classList.add('wrong-slot');
  });
  const r=document.getElementById('sortResult');r.style.display='block';
  if(total===0){r.style.background='#fff3cd';r.style.color='#856404';r.textContent='⚠️ Drag cards into columns first!';return;}
  if(correct===12&&total===12){r.style.background='var(--green-bg)';r.style.color='var(--green)';r.textContent='✅ All 12 cards correctly sorted!';markDone('C','pd3');}
  else{r.style.background='#fff8ee';r.style.color='#7a4800';r.textContent=correct+'/'+total+' correct. Red cards are wrong — try moving them.';}
}
function resetSort(){
  const bank=document.getElementById('sortBank');
  document.querySelectorAll('.sort-card').forEach(c=>{c.classList.remove('correct-slot','wrong-slot');c.style.opacity='1';bank.appendChild(c);});
  document.getElementById('sortResult').style.display='none';
}

/* ═══ ACTIVITY D: WRONG WORD ═══ */
let wwFound=0;
function foundWW(el){
  if(el.classList.contains('found'))return;
  el.classList.add('found');
  const fbId='ww'+(Array.from(document.querySelectorAll('.wrong-word')).indexOf(el)+1);
  const fb=document.getElementById(fbId);if(fb){fb.style.display='block';}
  wwFound++;
}
function checkAllWW(){
  const wws=document.querySelectorAll('.wrong-word');
  wws.forEach(w=>{if(!w.classList.contains('found'))w.classList.add('missed');});
  const fb=document.getElementById('wwFeedback');fb.style.display='block';
  if(wwFound===5){
    fb.style.background='var(--green-bg)';fb.style.color='var(--green)';
    fb.textContent='✅ All 5 errors found — great attention to detail!';
    markDone('D','pd4');
  }else{
    fb.style.background='#fff8ee';fb.style.color='#7a4800';
    fb.textContent=wwFound+'/5 found. Missed ones are outlined in red — click them to reveal the correction.';
  }
}
</script>
</body>
